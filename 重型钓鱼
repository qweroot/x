}

local function findBossZone()
    local bossZonesFolder = workspace:FindFirstChild("BossZones")
    if not bossZonesFolder then return nil end
    for _, folder in ipairs(bossZonesFolder:GetChildren()) do
        local zone = folder:FindFirstChild("BossSpawnZone")
        if zone then return zone end
    end
    return nil
end

local function getClosestSellPoint(pos)
    local best, dist = nil, math.huge
    for _, p in ipairs(sellPoints) do
        local d = (pos - p).Magnitude
        if d < dist then
            best = p
            dist = d
        end
    end
    return best
end

local function getInvCount()
    local c = 0
    local bp = lplr.Backpack
    local char = lplr.Character
    if bp then c = c + #bp:GetChildren() end
    if char then for _,v in ipairs(char:GetChildren()) do if v:IsA("Tool") then c = c + 1 end end end
    return c
end

local function smoothTP(cf, sp)
    local char = lplr.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    sp = sp or 160
    local dist = (hrp.Position - cf.Position).Magnitude
    local t = TweenService:Create(hrp, TweenInfo.new(dist/sp), {CFrame = cf})
    local con = RunService.Stepped:Connect(function()
        for _,v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end)
    t:Play()
    t.Completed:Wait()
    con:Disconnect()
end

