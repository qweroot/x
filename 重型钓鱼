local function findBossZone()
    local f = workspace:FindFirstChild("BossZones")
    if not f then return nil end
    for _,v in ipairs(f:GetChildren()) do
        local z = v:FindFirstChild("BossSpawnZone")
        if z then return z end
    end
    return nil
end

local function getClosestSellPoint(pos)
    local best, dist = nil, math.huge
    for _,p in ipairs(sellPoints) do
        local d = (pos-p).Magnitude
        if d < dist then best, dist = p, d end
    end
    return best
end

