})

local ToggleSell = Tab:Toggle({
    Title = "自动卖鱼",
    Desc = "满了自动卖",
    Type = "Checkbox",
    Callback = function(state)
        autoSellEnabled = state
        if state then
            task.spawn(function()
                while autoSellEnabled do
                    task.wait(1)
                    if not isTeleporting and not isBossTeleporting and not bossActive then
                        if getInvCount() >= sellThreshold then
                            local hrp = lplr.Character and lplr.Character.HumanoidRootPart
                            if hrp then
                                fishOriginalLocation = hrp.CFrame
                                local p = getClosestSellPoint(hrp.Position)
                                if p then
                                    isTeleporting = true
                                    smoothTP(CFrame.new(p))
                                    repeat task.wait(0.5) until getInvCount() < 2 or not autoSellEnabled
                                    smoothTP(fishOriginalLocation)
                                    isTeleporting = false
                                end
                            end
                        end
                    end
                end
            end)
        end
    end
})

local ToggleBoss = Tab:Toggle({
    Title = "自动BOSS传送",
    Type = "Checkbox",
    Callback = function(state)
        AutoTPBoss = state
        if state then
            task.spawn(function()
                while AutoTPBoss do
                    task.wait(0.5)
                    local z = findBossZone()
                    if z and not bossActive then
                        bossActive = true
                        local hrp = lplr.Character and lplr.Character.HumanoidRootPart
                        if hrp then
                            originalLocation = hrp.CFrame
                            isBossTeleporting = true
                            smoothTP(z:IsA("Model") and z:GetModelCFrame() or z.CFrame, 200)
                            isBossTeleporting = false
                        end
                    elseif not z and bossActive then
                        bossActive = false
                        if originalLocation then
                            smoothTP(originalLocation)
                            originalLocation = nil
                        end
                    end
                end
            end)
        end
    end
})

